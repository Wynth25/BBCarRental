<div class="form-container">
  <h1>Nová rezervace</h1>

  <%= form_with model: @reservation, local: true, class: "modern-form" do |form| %>
    <%= hidden_field_tag :source, (params[:source] || params[:reservation_source]) %>
    
    <% if @reservation.errors.any? %>
      <div class="error-box">
        <strong>Nelze uložit rezervaci:</strong>
        <ul>
          <% @reservation.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :user_id, "Uživatel", class: "form-label" %>
      
      <% if params[:source] == 'profile' && @reservation.user_id.present? %>

        <div class="form-control" style="background-color: #e9ecef; color: #6c757d; pointer-events: none;">
          <%= @reservation.user.name %></div>
        <%= form.hidden_field :user_id %>

      <% else %>

        <%= form.collection_select :user_id, User.all, :id, :name, { prompt: "Vyberte uživatele..." }, class: "form-control" %>
      <% end %>

    </div>

    <div class="form-group">
      <%= form.label :car_id, "Auto", class: "form-label" %>
      <%= form.collection_select :car_id, Car.all, :id, ->(car) { "#{car.brand} #{car.name} (#{car.year})" }, { prompt: "Vyberte auto..." }, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :start_date, "Od", class: "form-label" %>
      <%= form.date_field :start_date, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :end_date, "Do", class: "form-label" %>
      <%= form.date_field :end_date, class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Vytvořit rezervaci", class: "nav-btn active" %>
      <%= link_to "Zpět", reservations_path, class: "nav-btn" %>
    </div>
    
  <% end %>
</div>