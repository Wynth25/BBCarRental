<div class="form-container">
  <h1>Úprava uživatele</h1>

  <%= form_with model: @user, local: true, class: "modern-form" do |form| %>
    <%= hidden_field_tag :source, (params[:source] || params[:reservation_source]) %>

    <% if @user.errors.any? %>
      <div class="error-box">
        <strong>Nelze uložit uživatele:</strong>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, "Jméno a příjmení", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :email, "E-mail", class: "form-label" %>
      <%= form.email_field :email, class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Uložit změny", class: "nav-btn active" %>
      <% if params[:source] == 'profile' %>
        <%= link_to "Zrušit", user_path(@user), class: "nav-btn" %>
      <% else %>
         <%= link_to "Zrušit", users_path, class: "nav-btn" %>
      <% end %>
    </div>
    
  <% end %>